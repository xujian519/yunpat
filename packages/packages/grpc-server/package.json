{
  "name": "@yunpat/grpc-server",
  "version": "0.1.0",
  "description": "YunPat gRPC Server - TypeScript 实现",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "generate": "ts-proto --protoPath=../../protos --outputDir=src/generated",
    "test": "vitest --run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-proto": "^1.169.2",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "grpc",
    "yunpat",
    "agent"
  ],
  "author": "Xu Jian <xujian519@gmail.com>",
  "license": "MIT"
}
