# GLM (智谱 AI) API 配置示例
#
# 使用说明：
# 1. 复制此文件为 .env.glm
# 2. 填入你的 API Key
# 3. 运行测试：node scripts/check-glm-api.js

# ========== 必需配置 ==========

# GLM API Key（从 https://open.bigmodel.cn/ 获取）
# 格式：id.secret...（例如：1234567890.abcdef123456...）
GLM_API_KEY=your_glm_api_key_here

# ========== 可选配置 ==========

# GLM 模型选择
# 可选值：
#   - glm-5.1         (推荐，2026最新旗舰，综合能力最强)
#   - glm-4.7-flash   (推荐，极速响应，性价比最高)
#   - glm-4.7         (2025旗舰，综合能力强)
#   - glm-4.6-v       (视觉增强版，适合多模态任务)
#   - glm-4-flash     (快速响应，适合测试)
#   - glm-4-plus      (平衡性能)
#   - glm-4-air       (轻量级，成本较低)
#   - glm-4           (标准版本)
#   - glm-3-turbo     (旧版本，不推荐)
GLM_MODEL=glm-5.1

# ========== 其他配置 ==========

# API 端点（通常不需要修改）
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 请求超时时间（毫秒）
GLM_TIMEOUT=60000

# 最大重试次数
GLM_MAX_RETRIES=3

# ========== 使用提示 ==========

# 1. 快速测试：
#    export GLM_API_KEY=your_key
#    node scripts/check-glm-api.js

# 2. 在代码中使用：
#    import { createZhipuModel } from '@yunpat/core'
#    const llm = createZhipuModel(process.env.GLM_API_KEY)
#
#    const response = await llm.chat([
#      { role: 'user', content: '你好' }
#    ])
#    console.log(response.content)

# 3. 运行示例：
#    tsx examples/usage-glm-4-7-patent.ts

