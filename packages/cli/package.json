    "@yunpat/agent-quality": "workspace:*",
    "@yunpat/agent-researcher": "workspace:*",
    "@yunpat/agent-search": "workspace:*",
    "@yunpat/agent-specification": "workspace:*",
    "@yunpat/agent-writer": "workspace:*",
    "@yunpat/core": "workspace:*",
    "@yunpat/patent-tools": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/ora": "^3.2.0",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.2.0"
