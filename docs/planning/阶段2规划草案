## 把宪法层接入 Engine 主循环

在 `crates/tui/src/core/engine.rs` 里，在工具调用的**最前面**插入宪法检查，早于 `ExecPolicyEngine` 的三层规则，也早于 YOLO 的 `approval_policy = Never` 短路：

```rust
// crates/tui/src/core/engine.rs

async fn handle_tool_call(
    &mut self,
    tool_call: &ToolCall,
    mode:      &AgentMode,  // Plan / Agent / Yolo
) -> Result<ToolResult> {

    // ─── 宪法层（Layer 0）────────────────────────────────────────
    // 在 YOLO 短路之前运行，裁决不受 mode 影响
    let verdict = self.constitutional_engine.adjudicate(tool_call);

    match verdict {
        ConstitutionalVerdict::HardDeny { reason, audit_level } => {
            self.audit_log.write(AuditEntry {
                level:     audit_level,
                tool:      tool_call.name.clone(),
                action:    "constitutional_hard_deny".into(),
                reason:    reason.clone(),
                timestamp: Utc::now(),
                data_hash: tool_call.content_hash(),
            }).await?;

            // 在 transcript 里显示醒目的拒绝提示
            self.emit_constitutional_denial(&reason).await;
            return Ok(ToolResult::denied(reason));
        }

        ConstitutionalVerdict::RequireHuman { message, options, audit_level } => {
            // 无论是否 YOLO，强制弹出真人确认弹窗
            let approved = self.tui_handle
                .request_constitutional_approval(message, options)
                .await?;

            self.audit_log.write(AuditEntry {
                level:     audit_level,
                tool:      tool_call.name.clone(),
                action:    if approved { "human_approved" } else { "human_rejected" }.into(),
                timestamp: Utc::now(),
                data_hash: tool_call.content_hash(),
                reason:    "constitutional_require_human".into(),
            }).await?;

            if !approved {
                return Ok(ToolResult::cancelled("人工审核：操作已取消"));
            }
            // 人工确认后，继续走常规流程（不再经过 YOLO 短路）
        }

        ConstitutionalVerdict::RouteToLocal { local_base_url, local_model, reason } => {
            tracing::info!("[宪法] 数据主权路由: {} -> {}", reason, local_model);
            // 用本地客户端替换当前 turn 的 LLM 客户端
            return self.run_tool_with_local_client(
                tool_call,
                &local_base_url,
                &local_model,
            ).await;
        }

        ConstitutionalVerdict::Pass => {
            // 进入常规 execpolicy 流程（Layer 1–3 + YOLO）
        }
    }

    // ─── 常规 ExecPolicyEngine（Layer 1–3）+ YOLO 短路 ──────────
    self.exec_policy_engine
        .evaluate_and_execute(tool_call, mode)
        .await
}
```

