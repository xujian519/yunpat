{
  "name": "yunpat-agent-framework",
  "version": "0.1.0",
  "description": "通用智能体框架 - 框架笨，智能体专",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/agents/*"
  ],
  "scripts": {
    "dev": "pnpm --filter ./packages/* dev",
    "dev:start": "bash scripts/dev-start.sh",
    "build": "node esbuild.config.mjs build",
    "build:tsc": "pnpm -r --filter './packages/*' --filter './packages/agents/*' build",
    "build:watch": "node esbuild.config.mjs watch",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter @yunpat/core test -- --run",
    "test:real": "RUN_REAL_LLM_TESTS=true pnpm --filter @yunpat/core test -- --run",
    "test:mock": "MOCK_TESTS=true pnpm --filter @yunpat/core test -- --run",
    "test:watch": "pnpm --filter @yunpat/core test -- --watch",
    "test:coverage": "pnpm --filter @yunpat/core test -- --coverage",
    "test:e2e": "pnpm exec vitest run --root tests/e2e",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r --filter './packages/*' --filter './packages/agents/*' exec eslint --fix src --ext .ts",
    "lint:fix:all": "pnpm -r --filter './packages/*' --filter './packages/agents/*' exec eslint --fix src --ext .ts --max-warnings 1000",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md,yml,yaml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,md,yml,yaml}'",
    "type-check": "pnpm build:tsc",
    "ci": "bash scripts/ci-local.sh quick",
    "ci:full": "pnpm lint && pnpm type-check && pnpm test && pnpm build",
    "ci:legacy": "bash scripts/ci-check.sh",
    "dev:watch": "bash scripts/dev-watch.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:gateway": "bash scripts/dev-start.sh --gateway",
    "dev:adapter": "bash scripts/dev-start.sh --adapter",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "prepare": "husky",
    "deploy": "bash scripts/deploy-local.sh development deploy",
    "deploy:staging": "bash scripts/deploy-local.sh staging deploy",
    "deploy:prod": "bash scripts/deploy-local.sh production deploy",
    "deploy:rollback": "bash scripts/deploy-local.sh development rollback",
    "deploy:status": "bash scripts/deploy-local.sh development status",
    "deploy:legacy": "bash scripts/deploy.sh $1",
    "api:check-deepseek": "node scripts/check-api-key.js",
    "api:check-glm": "node scripts/check-glm-api.js",
    "doc:check": "node scripts/check-doc-sync.js",
    "doc:review": "node scripts/evaluate-completion.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "skills:keygen": "npx tsx scripts/seal-skills.ts --keygen",
    "skills:seal": "npx tsx scripts/seal-skills.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "langchain",
    "framework",
    "typescript"
  ],
  "author": "Xu Jian <xujian519@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pdf-parse": "^1.1.4",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3"
  }
}
