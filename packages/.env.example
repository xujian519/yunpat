# YunPat 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 最后更新：2026-05-01

# ============================================
# LLM API 配置（至少配置一个）
# ============================================

# DeepSeek API（推荐，性价比高，默认使用）
# 支持：deepseek-v4-flash, deepseek-v4-pro, deepseek-chat, deepseek-coder
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 API（分析任务推荐）
# 支持：qwen-turbo, qwen-plus, qwen-max
# 获取 API Key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-qwen-api-key-here

# 智谱 GLM API（编程任务推荐，已集成）
# 支持：glm-4-flash, glm-4-plus, glm-4.7, glm-4-air
# 获取 API Key: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4-flash

# 本地 Ollama（离线场景）
# 支持：llama3, mistral, qwen, deepseek-chat
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen

# 本地 OMLX（Apple Silicon 本地模型，免费）
# 安装：brew install mlx-omlx
# 文档：https://github.com/ml-explore/mlx-ommx
OMLX_BASE_URL=http://localhost:8009/v1
OMLX_API_KEY=your-omlx-api-key-here
OMLX_MODEL_NAME=Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit
OMLX_ENABLED=true

# ============================================
# 知识库配置（专利智能体核心依赖）
# ============================================

# Obsidian 知识库路径（宝宸知识库）
# 项目内副本：./knowledge-base
# iCloud 原路径：~/Library/Mobile Documents/iCloud~md~obsidian/Documents/宝宸知识库
KNOWLEDGE_BASE_PATH=./knowledge-base

# 提示词模板目录
PROMPT_TEMPLATES_DIR=./prompts/patent-drafting

# ============================================
# 数据库配置（可选，用于持久化存储）
# ============================================

# PostgreSQL（生产环境推荐）
DATABASE_URL=postgresql://yunpat:yunpat123@localhost:5432/yunpat

# PostgreSQL 测试数据库
TEST_DATABASE_URL=postgresql://yunpat:yunpat123@localhost:5432/yunpat_test

# Redis（缓存和会话管理）
REDIS_URL=redis://localhost:6379

# ============================================
# 服务端口配置
# ============================================

# API 网关端口
API_PORT=3000

# gRPC 服务端口
GRPC_PORT=50051

# WebSocket 服务端口
WS_PORT=3001

# ============================================
# 应用配置
# ============================================

# 环境：development | production | test
NODE_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai

# ============================================
# 第三方服务配置
# ============================================

# 专利数据库 API（如需要）
PATENT_API_KEY=your-patent-database-api-key
PATENT_API_URL=https://api.patent-database.com

# 文件存储（OSS/S3）
STORAGE_TYPE=local
# STORAGE_TYPE=oss
# OSS_ACCESS_KEY_ID=your-access-key
# OSS_ACCESS_KEY_SECRET=your-secret-key
# OSS_BUCKET=yunpat-docs
# OSS_REGION=oss-cn-hangzhou

# ============================================
# 监控和日志
# ============================================

# Sentry 错误追踪
SENTRY_DSN=your-sentry-dsn

# 日志服务
# LOGGING_SERVICE=elasticsearch
# ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# 安全配置
# ============================================

# JWT 密钥（生产环境必须更改）
JWT_SECRET=your-jwt-secret-key

# 加密密钥（生产环境必须更改）
ENCRYPTION_KEY=your-encryption-key

# OAuth 2.0 Token 加密密钥（32 字节以上）
OAUTH_ENCRYPTION_KEY=your-oauth-encryption-key-32-bytes-long

# CORS 允许的源
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# OAuth 2.0 配置
# ============================================

# Google OAuth 2.0
# 获取凭证：https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth 2.0
# 获取凭证：https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# OAuth 重定向 URI
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/dashboard
OAUTH_FAILURE_REDIRECT=http://localhost:3000/login

# ============================================
# 限制配置
# ============================================

# 并发请求数限制
MAX_CONCURRENT_REQUESTS=10

# 单次请求超时（毫秒）
REQUEST_TIMEOUT=60000

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# ============================================
# 功能开关
# ============================================

# 启用缓存
ENABLE_CACHE=true

# 启用监控
ENABLE_MONITORING=true

# 启用分析
ENABLE_ANALYTICS=false

# ============================================
# 开发工具
# ============================================

# 启用热重载
HMR=true

# 启用调试模式
DEBUG=false

# ============================================
# Python 服务配置（多语言架构）
# ============================================

# Python 服务端口（ML/数据分析）
PYTHON_SERVICE_PORT=8000

# Python 服务 URL
PYTHON_SERVICE_URL=http://localhost:8000

# ============================================
# Rust 服务配置（多语言架构）
# ============================================

# Rust 服务端口（性能关键型算法）
RUST_SERVICE_PORT=9000

# Rust 服务 URL
RUST_SERVICE_URL=http://localhost:9000

# ============================================
# 项目当前状态说明（2026-05-01）
# ============================================

# 总体进度：~75%（基于实际代码审计，详见 README.md）
# - 核心框架：95%
# - 知识库集成：100%
# - 专利数据库/检索/分析/答复：100%
# - PatentWriterAgent：85%
# - Rust 工具链：85%（FFI 安全加固完成）
# - TUI 界面：进行中（替代 CLI）

# 推荐配置（最小可用）：
# 1. DEEPSEEK_API_KEY - 必需，用于推理层和智能体
# 2. KNOWLEDGE_BASE_PATH - 必需，专利智能体依赖
# 3. PROMPT_TEMPLATES_DIR - 必需，提示词模板路径

# 可选配置（增强功能）：
# - DASHSCOPE_API_KEY - 分析任务备用
# - GLM_API_KEY - 编程任务专用
# - DATABASE_URL - 持久化存储
# - REDIS_URL - 缓存和会话

# 开发测试命令：
# pnpm test                    # 运行所有测试
# pnpm --filter @yunpat/core test  # 核心包测试
# pnpm build                   # 构建项目
# ./test-glm.sh               # 测试 GLM 集成

# ============================================
# 注意事项
# ============================================

# 1. 不要将 .env 文件提交到 Git 仓库
# 2. 生产环境请使用强密码和密钥
# 3. 定期轮换 API 密钥
# 4. 敏感信息使用环境变量，不要硬编码
# 5. 测试需要真实 API Key（DEEPSEEK_API_KEY 或 GLM_API_KEY）
