# YunPat Gateway + TUI 环境配置示例
# 复制为 .env.local 使用

# ===== 网关意图路由器 LLM 配置 =====
# 推荐使用 DeepSeek（编程能力强、价格低）
ROUTER_LLM_BASE_URL=https://api.deepseek.com/v1
ROUTER_LLM_API_KEY=your_deepseek_api_key_here
ROUTER_LLM_MODEL=deepseek-chat

# 备选：使用 OpenAI
# ROUTER_LLM_BASE_URL=https://api.openai.com/v1
# ROUTER_LLM_API_KEY=your_openai_api_key_here
# ROUTER_LLM_MODEL=gpt-4o-mini

# 备选：使用本地 oMLX
# ROUTER_LLM_BASE_URL=http://localhost:8009/v1
# ROUTER_LLM_API_KEY=your_omlx_api_key_here
# ROUTER_LLM_MODEL=Qwen3.5-27B-4bit

# ===== Orchestrator 主 LLM =====
MODEL_PROVIDER=zhipu
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4.7-flash

# ===== oMLX 多模态/嵌入 =====
OMLX_BASE_URL=http://localhost:8009
OMLX_API_KEY=your_omlx_api_key_here
OMLX_MULTIMODAL_MODEL=glm-4v
OMLX_EMBEDDING_MODEL=bge-m3

# ===== 服务端口 =====
GATEWAY_PORT=8080
ORCHESTRATOR_URL=http://localhost:3001
