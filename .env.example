# YunPat 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# LLM API 配置（至少配置一个）
# ============================================

# DeepSeek API（推荐，性价比高）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 API（分析任务推荐）
DASHSCOPE_API_KEY=sk-your-qwen-api-key-here

# 本地 Ollama（离线场景）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-chat

# ============================================
# 数据库配置
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/yunpat

# Redis
REDIS_URL=redis://localhost:6379

# ============================================
# 服务端口配置
# ============================================

# API 网关端口
API_PORT=3000

# gRPC 服务端口
GRPC_PORT=50051

# WebSocket 服务端口
WS_PORT=3001

# ============================================
# 应用配置
# ============================================

# 环境：development | production | test
NODE_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai

# ============================================
# 第三方服务配置
# ============================================

# 专利数据库 API（如需要）
PATENT_API_KEY=your-patent-database-api-key
PATENT_API_URL=https://api.patent-database.com

# 文件存储（OSS/S3）
STORAGE_TYPE=local
# STORAGE_TYPE=oss
# OSS_ACCESS_KEY_ID=your-access-key
# OSS_ACCESS_KEY_SECRET=your-secret-key
# OSS_BUCKET=yunpat-docs
# OSS_REGION=oss-cn-hangzhou

# ============================================
# 监控和日志
# ============================================

# Sentry 错误追踪
SENTRY_DSN=your-sentry-dsn

# 日志服务
# LOGGING_SERVICE=elasticsearch
# ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# 安全配置
# ============================================

# JWT 密钥
JWT_SECRET=your-jwt-secret-key

# 加密密钥
ENCRYPTION_KEY=your-encryption-key

# CORS 允许的源
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# 限制配置
# ============================================

# 并发请求数限制
MAX_CONCURRENT_REQUESTS=10

# 单次请求超时（毫秒）
REQUEST_TIMEOUT=60000

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# ============================================
# 功能开关
# ============================================

# 启用缓存
ENABLE_CACHE=true

# 启用监控
ENABLE_MONITORING=true

# 启用分析
ENABLE_ANALYTICS=false

# ============================================
# 开发工具
# ============================================

# 启用热重载
HMR=true

# 启用调试模式
DEBUG=false

# ============================================
# Python 服务配置（多语言架构）
# ============================================

# Python 服务端口
PYTHON_SERVICE_PORT=8000

# Python 服务 URL
PYTHON_SERVICE_URL=http://localhost:8000

# ============================================
# Rust 服务配置（多语言架构）
# ============================================

# Rust 服务端口
RUST_SERVICE_PORT=9000

# Rust 服务 URL
RUST_SERVICE_URL=http://localhost:9000

# ============================================
# 注意事项
# ============================================

# 1. 不要将 .env 文件提交到 Git 仓库
# 2. 生产环境请使用强密码和密钥
# 3. 定期轮换 API 密钥
# 4. 敏感信息使用环境变量，不要硬编码
