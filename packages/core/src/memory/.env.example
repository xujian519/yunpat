# 记忆层环境变量配置
#
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写你的实际配置
# 3. 在应用启动前加载：source .env

# ============ BGE-M3 嵌入模型配置 ============

# BGE-M3 API 密钥（必需，如果启用 RAG）
BGE_API_KEY=your-api-key-here

# BGE-M3 服务地址（可选，默认 http://localhost:8009/v1）
# BGE_BASE_URL=http://localhost:8009/v1

# ============ PostgreSQL 数据库配置 ============

# 数据库连接 URL（必需）
DATABASE_URL=postgres://yunpat:yunpat123@localhost:5432/yunpat

# 或者使用单独的配置：
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=yunpat
# POSTGRES_PASSWORD=yunpat123
# POSTGRES_DATABASE=yunpat

# ============ 向量配置 ============

# 向量维度（可选，默认 1024）
# VECTOR_DIMENSION=1024

# ============ Token 窗口配置 ============

# 最大 Token 数（可选，默认 4000）
# MAX_TOKENS=4000

# ============ 缓存配置 ============

# BGE-M3 缓存最大条目数（可选，默认 1000）
# BGE_CACHE_MAX_SIZE=1000

# ============ 功能开关 ============

# 是否启用 RAG（可选，默认 true）
# ENABLE_RAG=true

# 是否启用 Token 窗口（可选，默认 true）
# ENABLE_TOKEN_WINDOW=true
