## 第二层：MCP 工具级别的细粒度门控（Hook 实现）

execpolicy 的 `auto_allow`/`auto_deny` 只能做**命令前缀匹配**，无法检查工具调用的**参数内容**。专利场景需要更细的控制：同一个 `patent_draft_full` 工具，传入"简单机械结构"和传入"核心算法技术方案"应该走不同的审批流程。

用 `tool_call_before` Hook 实现参数级门控：

```toml
# .deepseek/config.toml 追加
[[hooks.events]]
event   = "tool_call_before"
command = "node"
args    = ["/path/to/yunpat/packages/execpolicy-hook/dist/index.js"]
timeout = 3
output  = "jsonl"
```

```typescript
// packages/execpolicy-hook/src/index.ts
// 在每次工具调用前运行，对专利工具做参数级安全检查

interface ToolCallContext {
  event:     'tool_call_before'
  tool:      string         // e.g. "mcp_yunpat_patent_draft_full"
  arguments: Record<string, unknown>
  session:   string
  mode:      string         // plan / agent / yolo
}

const ctx = JSON.parse(await readStdin()) as ToolCallContext

// 只拦截专利工具
if (!ctx.tool.startsWith('mcp_yunpat_')) {
  process.exit(0)  // 非专利工具：放行
}

const decision = await evaluatePatentToolCall(ctx)

// 输出决策指令
console.log(JSON.stringify(decision))

// ─────────────────────────────────────────────
async function evaluatePatentToolCall(
  ctx: ToolCallContext,
): Promise<PolicyDecision> {
  const args = ctx.arguments

  switch (ctx.tool) {

    // patent_draft_full：检查技术交底书的敏感度
    case 'mcp_yunpat_patent_draft_full': {
      const disclosure = String(args.disclosure ?? '')
      const sensitivity = assessSensitivity(disclosure)

      if (sensitivity === 'extreme') {
        // 包含高度敏感关键词（核心算法、军事应用等）
        return {
          action:  'require_approval',
          message: `⚠️ 检测到高敏感度技术交底书\n\n` +
                   `敏感词：${sensitivity.keywords.join('、')}\n` +
                   `建议：确认使用本地 Ollama 模型处理，而非外部 API`,
          options: ['使用本地模型处理', '使用外部 API（我已确认）', '取消'],
        }
      }

      if (ctx.mode === 'yolo' && sensitivity !== 'low') {
        // YOLO 模式下：中等敏感度也要求确认
        return {
          action:  'require_approval',
          message: `YOLO 模式下检测到敏感技术内容，专利数据主权保护强制要求确认`,
          options: ['确认继续', '取消'],
        }
      }

      return { action: 'allow' }
    }

    // patent_submit：不可逆操作，强制二次确认
    case 'mcp_yunpat_patent_submit': {
      const appNumber = String(args.application_number ?? '未知')
      return {
        action:   'require_approval',
        blocking: true,   // 即使 YOLO 模式也阻断
        message:  `🚨 不可逆操作：正式提交专利申请\n\n` +
                  `申请号：${appNumber}\n` +
                  `目标局：${args.office ?? '中国国家知识产权局'}\n\n` +
                  `此操作提交后无法撤回，请确认申请文件已经完整审核。`,
        options:  ['确认提交', '取消'],
        log_audit: true,  // 无论选择什么，记录审计日志
      }
    }

    // patent_respond：检查是否有不当让步措辞
    case 'mcp_yunpat_patent_respond': {
      const content = String(args.office_action ?? '')
      const hasConcessions = detectImproperConcessions(content)

      if (hasConcessions.found) {
        return {
          action:  'warn',    // 警告但不阻断
          message: `⚠️ 答复内容中检测到可能的不当让步措辞：\n` +
                   hasConcessions.examples.map(e => `  • ${e}`).join('\n') +
                   `\n\n建议在提交前由专利代理人复核。`,
        }
      }

      return { action: 'allow' }
    }

    default:
      return { action: 'allow' }
  }
}

// 敏感度评估：基于技术关键词
function assessSensitivity(text: string): SensitivityLevel {
  const extremeKeywords = [
    '军事', '武器', '核', '密码算法', '国防',
    'military', 'weapon', 'nuclear', 'encryption key',
  ]
  const highKeywords = [
    '核心算法', '底层协议', '密钥', '生物特征',
    'core algorithm', 'biometric', 'private key',
  ]

  const found = extremeKeywords.filter(k => text.includes(k))
  if (found.length > 0) return { level: 'extreme', keywords: found }

  const highFound = highKeywords.filter(k => text.includes(k))
  if (highFound.length > 0) return { level: 'high', keywords: highFound }

  return { level: 'low', keywords: [] }
}

// 检测不当让步措辞
function detectImproperConcessions(text: string): { found: boolean; examples: string[] } {
  const concessionPatterns = [
    /承认.*缺乏新颖性/,
    /同意审查员.*意见/,
    /确实.*不具备创造性/,
    /放弃.*权利要求/,
  ]
  const examples = concessionPatterns
    .map(p => { const m = text.match(p); return m ? m[0] : null })
    .filter(Boolean) as string[]

  return { found: examples.length > 0, examples }
}
