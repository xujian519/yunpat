struct DataSovereigntyPrinciple {
    local_base_url: String,
    local_model:    String,
    threshold:      f32,
}

impl ConstitutionalPrinciple for DataSovereigntyPrinciple {
    fn name(&self) -> &'static str { "data-sovereignty" }

    fn evaluate(&self, tool: &ToolCall) -> ConstitutionalVerdict {
        // 只对专利工具中涉及完整技术方案的工具生效
        let sensitivity = match tool.name.as_str() {
            "mcp_yunpat_patent_draft_full" => {
