{
  "name": "@yunpat/patent-database",
  "version": "0.0.1",
  "description": "专利数据库适配器 - 支持 patent_db (7500万CN专利) 和 Google Patents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@yunpat/core": "workspace:*",
    "pg": "^8.11.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "patent",
    "database",
    "adapter",
    "postgresql",
    "google-patents",
    "yunpat"
  ],
  "author": "Xu Jian <xujian519@gmail.com>",
  "license": "MIT"
}
