                Self::measure(disclosure)
            }
            "mcp_yunpat_patent_respond" => {
                let content = tool.arg_str("office_action").unwrap_or_default();
                Self::measure(content) * 0.8  // 答复内容敏感度稍低
            }
            "mcp_yunpat_patent_analyze" => {
                let text = tool.arg_str("patent_text").unwrap_or_default();
                Self::measure(text) * 0.7
            }
            _ => 0.0,
        };

        if sensitivity >= self.threshold {
            ConstitutionalVerdict::RouteToLocal {
                local_base_url: self.local_base_url.clone(),
                local_model:    self.local_model.clone(),
                reason: format!(
                    "技术内容敏感度 {:.0}%，超过数据主权阈值 {:.0}%，\
                     强制路由至本地模型以保护技术秘密",
                    sensitivity * 100.0,
                    self.threshold * 100.0,
                ),
            }
        } else {
            ConstitutionalVerdict::Pass
        }
    }
}

impl DataSovereigntyPrinciple {
    fn measure(text: &str) -> f32 {
        // 极敏感词（+0.3 per hit，上限 1.0）
        const EXTREME: &[&str] = &[
            "核心算法", "底层协议", "军事", "武器", "密码", "国防",
            "core algorithm", "military", "classified",
        ];
        // 高敏感词（+0.15 per hit）
        const HIGH: &[&str] = &[
            "专利技术", "技术秘密", "商业秘密", "未公开", "独家",
            "trade secret", "proprietary",
        ];
        let extreme_score = EXTREME.iter()
            .filter(|&&k| text.contains(k))
            .count() as f32 * 0.3;
        let high_score = HIGH.iter()
            .filter(|&&k| text.contains(k))
            .count() as f32 * 0.15;
        (extreme_score + high_score).min(1.0)
    }
}
