# 云熙知识产权智能体 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ⚠️ .env 文件不会被提交到Git（已添加到.gitignore）

# =============================================================================
# LLM API密钥（至少配置一个）
# =============================================================================

# DeepSeek API（推荐，性价比高）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 通义千问 API（备用）
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# OpenAI API（可选）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude API（可选）
# 获取地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-your-anthropic-api-key

# =============================================================================
# 本地模型（可选，用于敏感数据处理）
# =============================================================================

# Ollama本地模型服务
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL（生产环境）
DATABASE_URL=postgresql://user:password@localhost:5432/patent_db

# SQLite（开发环境，可选）
SQLITE_DATABASE_URL=file:./data/patent.db

# Redis缓存（可选）
REDIS_URL=redis://localhost:6379

# =============================================================================
# MCP配置
# =============================================================================

# MCP工具调用超时（秒）
MCP_TIMEOUT=300

# MCP最大重试次数
MCP_MAX_RETRIES=3

# MCP配置文件路径
MCP_CONFIG_PATH=~/.deepseek/mcp.json

# =============================================================================
# 应用配置
# =============================================================================

# 运行模式：development | staging | production
NODE_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 服务端口
PORT=8080

# =============================================================================
# 监控（可选）
# =============================================================================

# Prometheus指标端口
METRICS_PORT=3000

# Grafana管理员密码（Docker环境）
GRAFANA_ADMIN_PASSWORD=admin
