# YunPat 测试环境配置
# 复制此文件为 .env.test 并填入实际值

# ============================================
# LLM API 配置（至少配置一个）
# ============================================

# DeepSeek API（推荐，性价比高）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude（高质量）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI GPT
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# 本地 Ollama（免费）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen

# 本地 OMLX（免费，Apple Silicon）
OMLX_API_KEY=your-omlx-api-key-here
OMLX_BASE_URL=http://localhost:8009/v1
OMLX_MODEL_NAME=Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit
OMLX_ENABLED=true

# ============================================
# 测试配置
# ============================================

# 强制使用 Mock（跳过真实 API 调用）
# MOCK_TESTS=true

# 知识库路径
KNOWLEDGE_BASE_PATH=./knowledge-base

# ============================================
# 数据库配置（可选）
# ============================================

# 测试数据库
TEST_DATABASE_URL=postgresql://yunpat:yunpat123@localhost:5432/yunpat_test

# ============================================
# 注意事项
# ============================================

# 1. 真实 LLM 测试会产生 API 费用
# 2. 本地模型（Ollama/OMLX）免费但需要本地资源
# 3. 设置 MOCK_TESTS=true 可跳过所有 API 调用
# 4. 首次运行建议使用本地模型或 Mock 模式
