```rust
// crates/execpolicy/src/patent_rules.rs

use crate::{PolicyDecision, ToolCall};

pub struct PatentDataSovereigntyRule {
    pub local_model:    String,
    pub local_base_url: String,
    /// 触发本地路由的敏感度阈值（0.0–1.0）
    pub sensitivity_threshold: f32,
}

impl PatentDataSovereigntyRule {
    pub fn evaluate(&self, tool: &ToolCall) -> Option<PolicyDecision> {
        // 只对专利 MCP 工具生效
        if !tool.name.starts_with("mcp_yunpat_") {
            return None;
        }

        let sensitivity = self.measure_sensitivity(tool);

        if sensitivity >= self.sensitivity_threshold {
            Some(PolicyDecision::RouteToLocal {
                reason: format!(
                    "专利技术数据敏感度 {:.0}%，超过阈值 {:.0}%，强制路由到本地模型",
                    sensitivity * 100.0,
                    self.sensitivity_threshold * 100.0,
                ),
                local_model:    self.local_model.clone(),
                local_base_url: self.local_base_url.clone(),
            })
        } else {
            None
        }
    }

    fn measure_sensitivity(&self, tool: &ToolCall) -> f32 {
        // 工具类型基础敏感度
        let base = match tool.name.as_str() {
            "mcp_yunpat_patent_submit"    => 1.0,   // 提交：最高
            "mcp_yunpat_patent_draft_full" => 0.85,  // 撰写：高
            "mcp_yunpat_patent_respond"   => 0.75,  // 答复：高
            "mcp_yunpat_patent_analyze"   => 0.6,   // 分析：中
            "mcp_yunpat_patent_search"    => 0.2,   // 检索：低
            _                             => 0.3,
        };

        // 参数内容修正：检查是否含有极敏感关键词
        let content = tool.arguments_as_str();
        let keyword_boost = EXTREME_KEYWORDS
            .iter()
            .filter(|&&k| content.contains(k))
            .count() as f32 * 0.1;

        (base + keyword_boost).min(1.0)
    }
}

const EXTREME_KEYWORDS: &[&str] = &[
    "军事", "武器", "核", "密码", "国防",
    "military", "weapon", "classified",
];
