{
  "name": "@yunpat/unity-checker",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@yunpat/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
