{
  "name": "@yunpat/document-tools",
  "version": "0.1.0",
  "description": "YunPat 文档解析工具集 - 支持 PDF、DOCX、Excel、图片、音频等多种格式",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest --run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "yunpat",
    "document",
    "parser",
    "pdf",
    "docx",
    "excel",
    "ocr",
    "whisper"
  ],
  "author": "YunPat Team",
  "license": "MIT",
  "dependencies": {
    "@yunpat/core": "workspace:*",
    "docx": "^8.5.0",
    "form-data": "^4.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "nodejs-whisper": "^0.1.4",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "pptxgenjs": "^3.12.0",
    "tesseract.js": "^5.0.4",
    "turndown": "^7.1.2",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
