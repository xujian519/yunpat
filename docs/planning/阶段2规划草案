```rust
// 所有 patent_submit 操作，无论审批结果，都写入不可篡改的审计日志
struct SubmissionAuditPrinciple;

impl ConstitutionalPrinciple for SubmissionAuditPrinciple {
    fn name(&self) -> &'static str { "submission-audit" }

    fn evaluate(&self, tool: &ToolCall) -> ConstitutionalVerdict {
        // 本原则不阻断，只标记需要审计（由 IrreversibleActionPrinciple 负责阻断）
        // 此处确保即使其他原则 Pass，审计记录也一定被写入
        if tool.name.starts_with("mcp_yunpat_patent_submit") {
            // 通过 Pass + 副作用触发审计：
            // Engine 层在看到 AuditRequired 标记时写日志
            // 实际实现：在 Pass 裁决里携带 audit hint
            ConstitutionalVerdict::Pass  // IrreversibleActionPrinciple 会先返回 RequireHuman
        } else {
            ConstitutionalVerdict::Pass
        }
    }
}
