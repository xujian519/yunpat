# YunPat 快速开始配置
# 最小可用配置（2026-05-01）
# 复制此文件为 .env 并填入实际值

# ============================================
# 必需配置
# ============================================

# DeepSeek API Key（必需）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 知识库路径（必需，专利智能体依赖）
KNOWLEDGE_BASE_PATH=./knowledge-base

# 提示词模板目录（必需）
PROMPT_TEMPLATES_DIR=./prompts/patent-drafting

# ============================================
# 可选配置（推荐）
# ============================================

# 通义千问 API（分析任务备用）
# DASHSCOPE_API_KEY=sk-your-qwen-api-key-here

# 智谱 GLM API（编程任务专用）
# GLM_API_KEY=your-glm-api-key-here
# GLM_MODEL=glm-4-flash

# ============================================
# 快速验证
# ============================================

# 运行测试验证配置：
# pnpm test

# 测试 GLM 集成：
# source .env && ./test-glm.sh

# 查看完整配置选项：
# cat .env.example
