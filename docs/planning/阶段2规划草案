在 Engine 的工具调用路径里，`RouteToLocal` 决策触发时，临时替换当前 turn 的 LLM 客户端配置：

```rust
// crates/tui/src/core/engine.rs（简化示意）

async fn execute_tool_call(
    &mut self,
    tool_call: &ToolCall,
) -> Result<ToolResult> {
    // 先经过 execpolicy 决策
    let decision = self.policy_engine
        .evaluate(tool_call)
        .await?;

    match decision {
        PolicyDecision::Allow => {
            self.run_tool(tool_call).await
        }

        PolicyDecision::RouteToLocal { local_model, local_base_url, reason } => {
            // 把本次 LLM 调用临时重定向到本地 Ollama
            tracing::info!("数据主权路由：{} -> 本地模型 {}", reason, local_model);
            let local_client = self.client
                .with_override(local_base_url, local_model);
            self.run_tool_with_client(tool_call, &local_client).await
        }

        PolicyDecision::RequireApproval { message, options } => {
            // 弹出审批弹窗，等待用户确认
            let approved = self.tui_handle
                .request_approval(message, options)
                .await?;
            if approved {
                self.run_tool(tool_call).await
            } else {
                Ok(ToolResult::cancelled("用户取消"))
            }
        }

        PolicyDecision::Deny { reason } => {
            Ok(ToolResult::denied(reason))
        }

        PolicyDecision::AllowWithAudit { audit_event } => {
            self.audit_log.write(audit_event).await?;
            self.run_tool(tool_call).await
        }
    }
}
```

