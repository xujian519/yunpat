# GLM (智谱 AI) API 配置示例
#
# 使用说明：
# 1. 复制此文件为 .env.glm
# 2. 填入你的 API Key
# 3. 运行测试：npm run api:check-glm

# ========== 必需配置 ==========

# GLM API Key（从 https://open.bigmodel.cn/ 获取）
# 格式：id.secret...（例如：1234567890.abcdef123456...）
GLM_API_KEY=your_glm_api_key_here

# ========== 可选配置 ==========

# GLM 模型选择（通用端点）
# 可选值：
#   - glm-4.7        (推荐，2025最新旗舰，综合能力最强)
#   - glm-4-flash    (快速响应，适合测试)
#   - glm-4-plus     (平衡性能)
#   - glm-4-air      (轻量级，成本较低)
#   - glm-4          (标准版本)
#   - glm-3-turbo    (旧版本，不推荐)
GLM_MODEL=glm-4.7

# CodeGeeX 模型选择（编程端点）
# 可选值：
#   - codegeex-4         (推荐，最新代码模型)
#   - codegeex-4-all     (全能代码模型)
#   - codegeex-turbo     (快速代码模型)
CODEGEEX_MODEL=codegeex-4

# ========== 端点配置 ==========

# 通用端点（专利撰写、文本分析等）
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 编程端点（代码生成、代码分析等）
CODEGEEX_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4/

# ========== 其他配置 ==========

# 请求超时时间（毫秒）
GLM_TIMEOUT=60000

# 最大重试次数
GLM_MAX_RETRIES=3

# ========== 使用提示 ==========

# 1. 验证通用模型：
#    npm run api:check-glm
#
# 2. 验证编程套餐：
#    npm run api:check-codegeex
#
# 3. 在代码中使用通用模型：
#    import { createZhipuModel } from '@yunpat/core'
#    const llm = createZhipuModel(process.env.GLM_API_KEY)
#
# 4. 在代码中使用编程模型：
#    import { createZhipuCodingModel } from '@yunpat/core'
#    const llm = createZhipuCodingModel(process.env.GLM_API_KEY)
#
# 5. 运行示例：
#    tsx examples/usage-glm-4-7-patent.ts      # 通用模型示例
#    tsx examples/usage-codegeex-coding.ts      # 编程模型示例

# ========== 费用参考 ==========

# GLM-4.7 定价（2025年）：
# - 输入：¥0.05/1K tokens
# - 输出：¥0.1/1K tokens
#
# CodeGeeX-4 定价（参考）：
# - 输入：¥0.05/1K tokens
# - 输出：¥0.1/1K tokens
#
# 估算：
# - 专利撰写（约15K tokens）：¥0.75-1.5
# - 代码生成（约3K tokens）：¥0.15-0.3
#
# 查看最新定价：https://open.bigmodel.cn/pricing

# ========== 模型选择建议 ==========

# 专利撰写任务 → 使用 GLM-4.7（通用端点）
# - 说明书撰写
# - 权利要求撰写
# - 技术方案分析
#
# 代码相关任务 → 使用 CodeGeeX-4（编程端点）
# - 代码生成
# - 代码理解
# - 代码审查
# - Bug 修复

# ========== 相关资源 ==========

# 官方文档：https://open.bigmodel.cn/dev/api
# 控制台：https://open.bigmodel.cn/usercenter
# CodeGeeX产品：https://open.bigmodel.cn/product/coding
