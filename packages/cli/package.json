{
  "name": "@yunpat/cli",
  "version": "0.1.0",
  "description": "YunPat CLI - 命令行工具",
  "type": "module",
  "bin": {
    "yunpat": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@yunpat/agent-analysis": "workspace:*",
    "@yunpat/agent-claims": "workspace:*",
