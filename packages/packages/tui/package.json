{
  "name": "@yunpat/tui",
  "version": "0.1.0",
  "description": "Terminal User Interface for YunPat - 自然语言交互的专利业务 TUI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "yunpat": "./dist/cli.js",
    "yunpat-tui": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx src/cli.tsx",
    "dev:watch": "cd ../.. && npx nodemon --watch packages/tui/src --ext ts,tsx,json --delay 1 --exec 'npx tsx packages/tui/src/cli.tsx'",
    "start": "node dist/cli.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest --run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "dependencies": {
    "@yunpat/core": "workspace:*",
    "@yunpat/agent-invention": "workspace:*",
    "@yunpat/agent-prior-art-search": "workspace:*",
    "@yunpat/agent-search": "workspace:*",
    "@yunpat/agent-claim-generator": "workspace:*",
    "@yunpat/agent-specification-drafter": "workspace:*",
    "@yunpat/agent-abstract-drafter": "workspace:*",
    "@yunpat/agent-analysis": "workspace:*",
    "@yunpat/agent-quality": "workspace:*",
    "@yunpat/agent-writer": "workspace:*",
    "@yunpat/agent-researcher": "workspace:*",
    "@yunpat/agent-patent-analyzer": "workspace:*",
    "@yunpat/agent-patent-responder": "workspace:*",
    "@yunpat/patent-tools": "workspace:*",
    "ansi-escapes": "^6.2.0",
    "chalk": "^5.3.0",
    "eventsource": "^4.1.0",
    "figures": "^6.0.1",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/ansi-escapes": "^4.0.0",
    "@types/eventsource": "^3.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "tui",
    "terminal",
    "cli",
    "ink",
    "patent"
  ],
  "author": "Xu Jian <xujian519@gmail.com>",
  "license": "MIT"
}
