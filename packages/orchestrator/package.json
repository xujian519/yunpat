{
  "name": "@yunpat/orchestrator",
  "version": "0.1.0",
  "description": "YunPat Orchestrator Agent - 中枢层智能调度系统",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "orchestrator",
    "agent",
    "llm",
    "patent",
    "yunpat"
  ],
  "author": "Xu Jian <xujian519@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@yunpat/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.15.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  }
}
