{
  "name": "@yunpat/builtin-tools",
  "version": "0.1.0",
  "description": "YunPat 内置工具集 - 文件操作、搜索、网络请求等常用工具",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest --run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "yunpat",
    "tools",
    "file",
    "search",
    "network"
  ],
  "author": "YunPat Team",
  "license": "MIT",
  "dependencies": {
    "@yunpat/core": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "typescript": "^5.x",
    "vitest": "^4.1.5"
  }
}
