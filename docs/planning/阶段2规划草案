        // 仅检查答复工具中的权利要求修改
        if tool.name != "mcp_yunpat_patent_respond" {
            return ConstitutionalVerdict::Pass;
        }

        let claims = tool.arg_str("patent_claims").unwrap_or_default();
        let proposed = tool.arg_str("proposed_claims").unwrap_or_default();

        if proposed.is_empty() {
            return ConstitutionalVerdict::Pass;
        }

        // 检测权利要求范围是否被主动扩大（危险操作）
        if Self::scope_expanded(claims, proposed) {
            ConstitutionalVerdict::RequireHuman {
                message: "⚠️ 检测到权利要求保护范围可能被扩大。\n\n\
                          专利答复中扩大权利要求范围通常是不被允许的，\
                          可能导致申请被驳回或无效。\n\n\
                          请人工确认此修改是有意为之且符合规定。"
                    .into(),
                options: vec![
                    "我已确认，此扩大符合修改规定".into(),
                    "取消，重新检查修改内容".into(),
                ],
                audit_level: AuditLevel::Warning,
            }
        } else {
            ConstitutionalVerdict::Pass
        }
    }
}

impl ClaimIntegrityPrinciple {
    // 简单启发：检查独立权利要求字数是否显著减少（特征被删除）
    fn scope_expanded(original: &str, proposed: &str) -> bool {
        let orig_len  = original.chars().count();
        let prop_len  = proposed.chars().count();
        // 权利要求字数减少超过 20% → 可能删除了限定特征 → 范围扩大
        prop_len < orig_len && (orig_len - prop_len) as f32 / orig_len as f32 > 0.2
    }
}
```

**原则四：禁止批量导出**

```rust
// 任何试图批量读取专利数据库并写出到外部的操作一律 HardDeny
struct BulkExportDenyPrinciple;

impl ConstitutionalPrinciple for BulkExportDenyPrinciple {
    fn name(&self) -> &'static str { "bulk-export-deny" }

    fn evaluate(&self, tool: &ToolCall) -> ConstitutionalVerdict {
        // 检测 exec_shell 里的批量导出命令模式
        if tool.name != "exec_shell" {
            return ConstitutionalVerdict::Pass;
        }

        let cmd = tool.arg_str("command").unwrap_or_default();
        let bulk_export_patterns = [
            "SELECT * FROM patents",
            "mongodump", "pg_dump", "mysqldump",
            "tar -c", "zip -r", "7z a",
            "aws s3 cp", "rclone copy",
        ];

        for pattern in &bulk_export_patterns {
            if cmd.contains(pattern) {
                return ConstitutionalVerdict::HardDeny {
                    reason: format!(
                        "宪法原则违反：检测到批量数据导出命令 `{}`。\n\
                         专利数据批量导出属于高风险操作，\
                         即使在 YOLO 模式下也被禁止。\n\
                         如需导出数据，请通过 YunPat 授权的数据管理接口操作。",
                        pattern
                    ),
                    audit_level: AuditLevel::Critical,
                };
            }
        }

        ConstitutionalVerdict::Pass
    }
}
